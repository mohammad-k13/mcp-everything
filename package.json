{
  "name": "mcp-everything",
  "module": "index.ts",
  "type": "module",
  "version": "1.0.0",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/mohammad-k13/mcp-everything.git"
  },
  "scripts": {
    "build": "tsc && shx cp -r docs dist/ && shx chmod +x dist/*.js",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "dev": "bun --hot dist/index.js",
    "start:stdio": "node dist/index.js stdio",
    "start:sse": "node dist/index.js sse",
    "start:streamableHttp": "node dist/index.js streamableHttp",
    "prettier:fix": "prettier --write .",
    "prettier:check": "prettier --check .",
    "test": "vitest run --coverage",
    "inspect": "npx modelcontextprotocol/inspector"
  },
  "bin": {
    "mcp-server-everything": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@vitest/coverage-v8": "^4.1.10",
    "prettier": "^3.9.4",
    "shx": "^0.4.0",
    "tsx": "^4.23.0",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jszip": "^3.10.1",
    "zod": "^4.4.3"
  }
}
